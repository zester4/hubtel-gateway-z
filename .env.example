PORT=3000
HUBTEL_GATEWAY_TOKEN=replace-with-long-random-token

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

HUBTEL_API_ID=
HUBTEL_API_KEY=
# Legacy aliases still work, but Hubtel Sales docs call these API ID/API Key.
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
# Optional: use product-specific Hubtel credentials/scopes when Hubtel gives separate API keys.
# Each *_BASIC_AUTH may be either the base64 token or the full "Basic <token>" value.
HUBTEL_CHECKOUT_API_ID=
HUBTEL_CHECKOUT_API_KEY=
HUBTEL_CHECKOUT_BASIC_AUTH=
HUBTEL_DIRECT_DEBIT_API_ID=
HUBTEL_DIRECT_DEBIT_API_KEY=
HUBTEL_DIRECT_DEBIT_BASIC_AUTH=
HUBTEL_RNV_API_ID=
HUBTEL_RNV_API_KEY=
HUBTEL_RNV_BASIC_AUTH=
HUBTEL_DISBURSEMENT_API_ID=
HUBTEL_DISBURSEMENT_API_KEY=
HUBTEL_DISBURSEMENT_BASIC_AUTH=
# Collection account (Online Checkout + transaction status + MoMo RNV)
HUBTEL_MERCHANT_ACCOUNT_NUMBER=
# Disbursement account (Direct Send Money + Send-To-Bank + send-money status)
HUBTEL_DISBURSEMENT_ACCOUNT_NUMBER=
# Defaults to https://payproxyapi.hubtel.com/items/initiate if omitted
HUBTEL_CHECKOUT_BASE_URL=https://payproxyapi.hubtel.com
# Optional overrides for Hubtel hosts (defaults match HUBTEL_CODE_DOC.md)
HUBTEL_TXN_STATUS_BASE_URL=https://api-txnstatus.hubtel.com
HUBTEL_SEND_STATUS_BASE_URL=https://smrsc.hubtel.com
HUBTEL_PREAPPROVAL_BASE_URL=https://preapproval.hubtel.com
HUBTEL_RECEIVE_MONEY_BASE_URL=https://rmp.hubtel.com
# Optional full POST URL for mobile-money send (else smp.hubtel.com/.../send/mobilemoney)
HUBTEL_SEND_MONEY_URL=
# Optional template for bank send: https://smp.hubtel.com/api/merchants/{acct}/send/bank/gh/{BankCode}
HUBTEL_SEND_TO_BANK_URL_TEMPLATE=
HUBTEL_CALLBACK_URL=
HUBTEL_PREAUTH_CALLBACK_URL=
HUBTEL_WEBHOOK_SECRET=
HUBTEL_BANKS_URL=
HUBTEL_BANK_VERIFY_URL=
HUBTEL_RNV_BASE_URL=https://rnv.hubtel.com

# Deprecated (previous generic /v1/disburse proxy). Disbursement uses smp.hubtel.com APIs above.
# HUBTEL_DISBURSEMENT_BASE_URL=
